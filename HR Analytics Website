        "proj3-p3": { en: "<strong>Key Insights:</strong> Attrition is notably higher among specific age groups. A clear inverse relationship exists between work-life balance metrics and employee turnover rates.", ar: "<strong>الرؤى الرئيسية:</strong> الاستقالة أعلى بين فئات عمرية محددة. توجد علاقة عكسية واضحة بين توازن العمل/الحياة ومعدلات الدوران." },
        "proj3-p4": { en: "<strong>Recommendations:</strong> Tailor retention strategies for high-risk age demographics, review the impact of mandatory overtime on attrition, and enact stricter policies to improve work-life balance.", ar: "<strong>التوصيات:</strong> تصميم استراتيجيات للاحتفاظ بالفئات العمرية عالية المخاطر، ومراجعة تأثير العمل الإضافي الإلزامي." },
        "proj3-btn": { en: "View Repository", ar: "عرض المستودع" },
        
        "contact-title": { en: "Ready to unlock your <span class=\"accent-text\">workforce potential?</span>", ar: "مستعد لإطلاق <span class=\"accent-text\">إمكانات قواك العاملة؟</span>" },
        "contact-sub": { en: "Let's collaborate on your next HR Data initiative.", ar: "دعونا نتعاون في مبادرة بيانات الموارد البشرية التالية الخاصة بك." },
        "contact-name": { en: "Your Name", ar: "الاسم" },
        "contact-email": { en: "Your Email", ar: "البريد الإلكتروني" },
        "contact-phone": { en: "Your Phone Number", ar: "رقم الهاتف" },
        "contact-msg": { en: "How can I help you?", ar: "كيف يمكنني مساعدتك؟" },
